# Local Docker Compose: enable bundled postgres and redis
COMPOSE_PROFILES=local

# Database
# Local Docker Compose (postgres service hostname is "postgres"):
# DATABASE_URL=postgres://devplatform:devplatform@postgres:5432/devplatform?sslmode=disable
# Local without Docker:
DATABASE_URL=postgres://devplatform:devplatform@localhost:5432/devplatform?sslmode=disable
# Optional: Redis for sessions (falls back to in-memory if unset or unavailable)
REDIS_URL=redis://localhost:6379/0
# Staging/production (set to your managed DB URL when deploying to app-dev.vibsl.com):
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/devplatform?sslmode=require
# REDIS_URL=redis://HOST:6379/0

# Server
PORT=8080
SESSION_SECRET=change-me-to-a-random-string-at-least-32-characters
FRONTEND_URL=http://localhost:8088
OAUTH_CALLBACK_BASE_URL=http://localhost:8088
COOKIE_SECURE=false

# OAuth - GitHub (required)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth - Google (bonus)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - GitLab (bonus)
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_BASE_URL=https://gitlab.com

# Worker
WORKER_CONCURRENCY=3
WORKER_POLL_INTERVAL=1s

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8088
API_INTERNAL_URL=http://localhost:8080
